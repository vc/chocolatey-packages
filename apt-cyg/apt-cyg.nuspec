<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>apt-cyg</id>
    <version>2025.09.03</version>
    <title>apt-cyg</title>
    <packageSourceUrl>https://github.com/vc/chocolatey-packages/tree/main/apt-cyg</packageSourceUrl>
    <authors>kou1okada</authors>
    <owners>Vasilii Strelok</owners>
    <projectUrl>https://github.com/kou1okada/apt-cyg</projectUrl>
    <licenseUrl>https://github.com/kou1okada/apt-cyg/blob/master/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Apt-cyg is a command-line installer for Cygwin which cooperates with Cygwin Setup and uses the same repository. The syntax is similar to apt-get.</description>
    <summary>apt-get like tool for Cygwin</summary>
    <tags>cygwin apt package-manager</tags>
    <dependencies>
      <dependency id="cygwin" version="3.0.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>